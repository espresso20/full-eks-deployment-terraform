# Copy this file to terraform.tfvars and edit.
# terraform.tfvars is gitignored.

region          = "us-west-2"
cluster_name    = "platform-lab"
cluster_version = "1.31"

# Required: a GitHub repo URL where you've pushed THIS lab repo.
# Argo CD will pull manifests from `gitops/` and `apps/` in that repo.
gitops_repo_url    = "https://github.com/YOUR_USERNAME/YOUR_REPO.git"
gitops_repo_branch = "main"

tags = {
  Project   = "platform-lab"
  ManagedBy = "terraform"
  Owner     = "adam"
}
